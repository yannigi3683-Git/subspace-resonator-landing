# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.

VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>

# Radio (P1). Site key is public by design; set in Vercel for all environments too.
VITE_TURNSTILE_SITE_KEY=<turnstile-site-key>

# Server-only secrets — set in Vercel project settings, NEVER with a VITE_ prefix:
#   SUPABASE_URL=https://<project-id>.supabase.co
#   SUPABASE_SECRET_KEY=sb_secret_<...>
#   CF_REALTIME_APP_ID=<cloudflare-realtime-app-id>
#   CF_REALTIME_APP_SECRET=<cloudflare-realtime-app-secret>
#   # Cloudflare Realtime TURN key (Realtime -> TURN). Lets the stream relay over TCP/TLS 443
#   # so it survives corporate firewalls / 4G CGNAT that kill the direct UDP path. Optional:
#   # without these the client falls back to STUN-only (current behaviour).
#   CF_TURN_KEY_ID=<turn-token-id>
#   CF_TURN_KEY_API_TOKEN=<turn-api-token>
